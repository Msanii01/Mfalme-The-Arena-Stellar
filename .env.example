# ============================================================
# MFALME ARENA — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the .env file. It is in .gitignore.
# ============================================================

# --- Server ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# --- Database (Supabase PostgreSQL) ---
# Get from: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:[your-password]@[your-project-ref].supabase.co:5432/postgres

# --- Stellar / Soroban ---
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Generate a fresh keypair at: https://laboratory.stellar.org
# Fund with XLM via: https://friendbot.stellar.org/?addr=YOUR_PUBLIC_KEY
PLATFORM_STELLAR_ADDRESS=                    # G... (your platform public key)
PLATFORM_STELLAR_SECRET=                     # S... (your platform secret key — NEVER share)

# Testnet USDC — Circle's official contract on Stellar Testnet
USDC_CONTRACT_ADDRESS=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Deployed after Phase 2 — soroban-cli deploy output
SOROBAN_CONTRACT_ADDRESS=

# --- x402 Payment Protocol (Built on Stellar Facilitator) ---
# Provided by OpenZeppelin — testnet key for Mfalme Arena
X402_API_KEY=                                # Your x402 API key
X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet

# --- Privy Authentication ---
# Get from: https://privy.io → Your App → Settings
PRIVY_APP_ID=                                # clx... (public, safe for frontend)
PRIVY_APP_SECRET=                            # KEEP SECRET — server-side only

# --- Riot Games API ---
# Get development key from: https://developer.riotgames.com
# If RIOT_API_KEY is absent → backend runs in SIMULATION mode automatically
RIOT_API_KEY=                                # RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Set by running: node backend/scripts/riot-setup.js provider
RIOT_PROVIDER_ID=
# Set by running: node backend/scripts/riot-setup.js tournament
RIOT_TOURNAMENT_ID=
# Public URL for Riot to POST match results to
# Local dev: use ngrok → ngrok http 3001 → copy https URL
# Deployed: https://your-render-url.onrender.com/webhooks/riot/result
RIOT_CALLBACK_URL=
RIOT_REGION_CLUSTER=americas                 # americas | europe | asia

# --- Challonge Bracket Engine ---
# Get from: https://challonge.com/settings/developer
# If CHALLONGE_API_KEY is absent → backend runs in SIMULATION mode automatically
CHALLONGE_API_KEY=
CHALLONGE_API_URL=https://api.challonge.com/v2.1

# --- Platform Fees ---
PLATFORM_FEE_PERCENT=5           # Deducted from 1v1 pot on settlement
UGT_PLATFORM_FEE_PERCENT=10      # Deducted from UGT prize pool
TOURNAMENT_FEE_PERCENT=10        # Deducted from platform tournament prize pool
