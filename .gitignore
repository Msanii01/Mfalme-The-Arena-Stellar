# ============================================================
# MFALME ARENA — .gitignore
# IMPORTANT: .env files are NEVER committed. See .env.example
# ============================================================

# --- Environment Variables (NEVER COMMIT) ---
.env
.env.local
.env.*.local
backend/.env
frontend/.env
*.env

# --- Node dependencies ---
node_modules/
frontend/node_modules/
backend/node_modules/

# --- Build outputs ---
dist/
build/
frontend/dist/
backend/dist/

# --- Rust / Soroban build artifacts ---
target/
contracts/target/
contracts/*/target/
**/*.wasm
!contracts/**/*.wasm.bak

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V4
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# --- Testing ---
coverage/
.nyc_output/

# --- Misc ---
.tmp/
*.tmp
.cache/
